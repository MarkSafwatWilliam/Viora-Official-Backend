{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ConnectionStrings": {
    "DefaultConnection": "Server=YOUR_SERVER;Database=VioraDB;Integrated Security=True;"
  },
  "Jwt": {
    "Key": "REPLACE_WITH_SECURE_SECRET_KEY",
    "Issuer": "VioraApp",
    "Audience": "VioraUsers",
    "TokenValidityMins": 15,
    "RefreshTokenValidityDays": 7
  },
  "ApiSettings": {
    "IntentEndPoint": "PLACEHOLDER_URL",
    "SpeechToTextEndPoint": "PLACEHOLDER_URL"
  }
}